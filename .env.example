# Privy wallet connection for the frontend.
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Optional server-side ChainGPT memo generation.
# If unset, ShadowRaise uses deterministic public signal memos.
CHAINGPT_API_KEY=

# Deployment wallet private key for Hardhat scripts.
# Never commit a real key. Prefer a funded testnet-only deployer.
PRIVATE_KEY=your_private_key_here

# Arbitrum Sepolia JSON-RPC endpoint.
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Frontend contract address after deployment.
NEXT_PUBLIC_SHADOWRAISE_CONTRACT_ADDRESS=
NEXT_PUBLIC_SHADOWRAISE_TOKEN_ADDRESS=
